{
  "repository": {
    "type": "git",
    "url": "git+https://github.com/y047aka/elm-starfighter.git"
  },
  "license": "CC0-1.0",
  "scripts": {
    "watch:html": "cpx -w src/index.html docs",
    "watch:assets": "cpx -w \"src/assets/**/*\" docs/assets",
    "watch:js": "cpx -w src/main.js docs",
    "watch:elm": "elm-live src/Main.elm --open --start-page=index.html --dir=docs -- --output=docs/elm.js",
    "watch:sass": "sass --watch src:docs",
    "build": "source build.sh",
    "start": "source start.sh",
    "test": "elm-test"
  },
  "devDependencies": {
    "cpx2": "^2.0.0",
    "elm": "^0.19.1-3",
    "elm-analyse": "^0.16.5",
    "elm-format": "^0.8.3",
    "elm-json": "^0.2.7",
    "elm-live": "^4.0.2",
    "elm-test": "^0.19.1-revision2",
    "google-closure-compiler": "^20200614.0.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.26.9"
  }
}
